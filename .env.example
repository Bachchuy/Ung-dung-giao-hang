# Supabase Configuration
# Replace these with your actual Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Telegram Bot Integration for instant dispatch channel
# Instructions to get these are detailed in the setup guide:
# 1. Create a bot via @BotFather on Telegram to get your TELEGRAM_BOT_TOKEN
# 2. Add your bot to a group channel and get the channel's TELEGRAM_CHAT_ID (e.g., -100xxxxxxxxxx)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
